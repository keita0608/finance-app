# ============================================================
# e-shiwake — Google Cloud Run 環境変数
# ============================================================
# このファイルをコピーして .env を作成し、実際の値を設定してください。
# Cloud Run へのデプロイ時はシークレットマネージャーまたは
# Cloud Run の環境変数設定から注入してください。
# ============================================================

# ---- Google Drive 設定 ----

# サービスアカウントキー（JSON 文字列）
# 取得方法:
#   1. Google Cloud Console → IAM と管理 → サービスアカウント
#   2. サービスアカウントを作成し「キーを追加」→「JSON」を選択
#   3. ダウンロードした JSON ファイルの内容を1行に圧縮して貼り付け
GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'

# データ保存先 Google Drive フォルダ ID
# 取得方法:
#   1. Google Drive でフォルダを作成
#   2. サービスアカウントのメールアドレスにフォルダの「編集者」権限を付与
#   3. フォルダの URL から ID を取得（https://drive.google.com/drive/folders/FOLDER_ID）
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# ---- アプリ設定 ----

# サーバーポート（Cloud Run はデフォルト 8080）
PORT=8080

# Node.js 環境
NODE_ENV=production
